rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Sessions Collection
    match /sessions/{sessionId} {
      // Allow read/list so users can see history
      allow read: if true;
      
      // Allow creation/updates for all associates
      // In a production app, we would restrict this to authenticated users
      allow create, update: if isValidId(sessionId);
      
      // Allow deletion
      allow delete: if true;
    }

    // Users (Associate Credentials) Collection
    match /users/{email} {
      // Allow single document 'get' for login verification
      allow get: if isValidId(email);
      
      // Admin management: Ideally restricted to the master admin email
      // For the purpose of this setup, we enable writes so the admin panel can work
      allow list, create, update, delete: if true;
    }

    // Flag Configuration
    match /flag_configs/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // Token Usage Collection
    match /token_usage/{docId} {
      allow create, read: if true;
      allow list: if true;
      // Validate required fields on create
      allow create: if 
        request.resource.data.associate_email is string &&
        request.resource.data.gl_id is string &&
        request.resource.data.product_name is string &&
        request.resource.data.prompt_tokens is number &&
        request.resource.data.completion_tokens is number &&
        request.resource.data.total_tokens is number &&
        request.resource.data.cost is number &&
        request.resource.data.model is string &&
        request.resource.data.analysis_type is string &&
        request.resource.data.status is string &&
        // case_study_id is optional, so no requirement
        (!('case_study_id' in request.resource.data) || request.resource.data.case_study_id is string);
    }
  }
}

