{
  "name": "ai-log-agent",
  "version": "1.0.0",
  "description": "Lightweight AI Agent with Python Proxy Bridge",
  "type": "module",
  "scripts": {
    "start": "node start.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite --port 3000 --host",
    "dev:backend": "python3 backend.py",
    "build": "vite build",
    "lint": "eslint .",
    "install-python": "pip install -r requirements.txt"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "framer-motion": "^12.34.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.56.1"
  }
}
